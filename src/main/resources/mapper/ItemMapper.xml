<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lostandfound.lostandfound.item.mapper.ItemMapper">

    <resultMap id="ItemResultMap" type="com.lostandfound.lostandfound.item.entity.Item">
        <id property="id" column="id"/>
        <result property="userId" column="userId"/>
        <result property="type" column="type"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="category" column="category"/>
        <result property="location" column="location"/>
        <result property="lostDate" column="lostDate"/>
        <result property="foundDate" column="foundDate"/>
        <result property="imageUrl" column="imageUrl"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="createdAt"/>
        <result property="updatedAt" column="updatedAt"/>
    </resultMap>

    <select id="findByCondition" resultMap="ItemResultMap">
        SELECT *
        FROM item
        <where>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (title LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY createdAt DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*)
        FROM item
        <where>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (title LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>

</mapper>